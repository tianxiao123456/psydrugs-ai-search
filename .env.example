# 复制为 .env 后填写（.env 已被 gitignore）

# --- OpenAI 官方 SDK（Embedding + Chat 共用，兼容 DeepSeek / Qwen 等）---
OPENAI_API_KEY=sk-your-key-here


# 兼容接口 Base URL（OpenAI 官方可留空；DeepSeek / Qwen 取消注释其一）
# OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_BASE_URL=https://api.deepseek.com/v1

# --- 模型名称 ---
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=deepseek-chat
# CHAT_MODEL=qwen-plus

# --- Chroma 本地向量库 ---
PSYDRUGS_SOURCE_DIR=psydrugs/source
CHROMA_PERSIST_DIR=data/chroma
CHROMA_COLLECTION=psydrugs_wiki

# --- 分块（建索引时用）---
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# --- RAG 检索片段数（接口限制 3–5，默认 5）---
SEARCH_TOP_K=5

# --- 超时与重试 ---
API_TIMEOUT_SECONDS=120
API_MAX_RETRIES=2

# --- Cloudflare Worker（cf-worker/，见 scripts/deploy_cf_worker.ps1）---
# 建索引需支持 text-embedding-3-small 的接口（常用 OpenAI 官方 URL）
# Worker 运行时变量在 cf-worker/wrangler.toml [vars] 中配置
