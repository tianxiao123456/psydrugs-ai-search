# 复制为 .env 后填写（.env 已被 gitignore）

# --- OpenAI 官方 SDK（Embedding + Chat 共用，兼容 DeepSeek / Qwen 等）---
OPENAI_API_KEY=YOUR_DEEPSEEK_R1_API_KEY

# 兼容接口 Base URL（OpenAI 官方可留空；DeepSeek / Qwen 示例见下）
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_BASE_URL=https://api.deepseek.com/v1

# --- 模型名称 ---
EMBEDDING_MODEL=deepseek-r1_psydrugs
CHAT_MODEL=deepseek-chat
# CHAT_MODEL=qwen-plus

# --- Chroma 本地向量库 ---
PSYDRUGS_SOURCE_DIR=psydrugs/source
CHROMA_PERSIST_DIR=data/chroma
CHROMA_COLLECTION=psydrugs_wiki

# --- 分块（建索引时用）---
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# --- RAG 检索片段数（接口限制 3–5，默认 5）---
SEARCH_TOP_K=5

# --- 超时与重试 ---
API_TIMEOUT_SECONDS=120
API_MAX_RETRIES=2
