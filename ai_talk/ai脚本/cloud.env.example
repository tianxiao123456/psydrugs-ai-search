# Copy to cloud.env and fill CURSOR_API_KEY (cloud.env is gitignored).
# PowerShell: Copy-Item cloud.env.example cloud.env
#
# Cloud Agents verify the repo via Cursor's GitHub App: link GitHub in Cursor Dashboard
# and grant this repo. Optional check: GET https://api.cursor.com/v1/repositories (same API key).
# Repo URL may omit .git (matches Cursor docs examples).

CURSOR_API_KEY=
CURSOR_CLOUD_REPO_URL=https://github.com/tianxiao123456/psydrugs-ai-search
CURSOR_CLOUD_REF=main

# Optional
# CURSOR_LOGIC_MODEL=gpt-5.5-medium
# CURSOR_QC_MODELS=composer-2-fast,gpt-5.5-medium
# GENERATE_BATCH_SIZE=4
# JSONL_LINES_PER_FILE=30
